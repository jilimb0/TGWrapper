{
  "name": "@tgwrapper/core",
  "version": "0.16.0",
  "description": "Serverless-first Telegram bot framework without external bot libraries",
  "repository": {
    "type": "git",
    "url": "https://github.com/jilimb0/TGWrapper"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/jilimb0/TGWrapper#readme",
  "bugs": {
    "url": "https://github.com/jilimb0/TGWrapper/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jilimb0"
  },
  "type": "module",
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm build:esm && pnpm build:cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:compat": "tsc -p tsconfig.type-tests.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "pnpm --filter @tgwrapper/adapter-redis test:integration",
    "test:load": "vitest run test/load/throughput.load.test.ts",
    "test:chaos": "vitest run test/chaos/multi-tenant.chaos.test.ts",
    "test:phase4": "pnpm test:load && pnpm test:chaos && pnpm test:integration",
    "benchmark": "pnpm build && node benchmark/run-benchmark.mjs",
    "benchmark:trend": "node scripts/check-benchmark-trend.mjs",
    "pack:size": "node scripts/check-package-size-budget.mjs",
    "pack:starters": "node scripts/check-starter-packages.mjs",
    "telegram:baseline:check": "node scripts/check-telegram-api-baseline.mjs",
    "telegram:baseline:latest": "node scripts/sync-telegram-api-baseline.mjs --check",
    "telegram:baseline:sync": "node scripts/sync-telegram-api-baseline.mjs --write",
    "telegram:baseline:followup:check": "node scripts/check-baseline-followup.mjs origin/main",
    "telegram:types:stub": "node scripts/generate-telegram-type-stubs.mjs",
    "telegram:schema:fetch": "node scripts/fetch-telegram-schema.mjs --out=docs/telegram-api-schema.latest.json",
    "telegram:schema:fetch:ci": "node scripts/fetch-telegram-schema.mjs --out=docs/telegram-api-schema.latest.json --allow-network-failure",
    "telegram:schema:fetch:local": "node scripts/fetch-telegram-schema.mjs --from-local --out=docs/telegram-api-schema.latest.json",
    "telegram:schema:completeness:check": "node scripts/check-telegram-schema-completeness.mjs",
    "telegram:schema:drift:report": "node scripts/diff-telegram-schema.mjs --latest=docs/telegram-api-schema.latest.json --snapshot=docs/telegram-api-schema.snapshot.json --report=docs/telegram-api-schema.drift-report.json",
    "telegram:schema:drift:check": "node scripts/diff-telegram-schema.mjs --latest=docs/telegram-api-schema.latest.json --snapshot=docs/telegram-api-schema.snapshot.json --report=docs/telegram-api-schema.drift-report.json --check",
    "telegram:schema:snapshot:update": "node scripts/promote-telegram-schema-snapshot.mjs",
    "telegram:schema:types:generate": "node scripts/generate-telegram-schema-types.mjs",
    "telegram:schema:types:check": "node scripts/check-telegram-schema-types-generated.mjs",
    "telegram:schema:payloads:generate": "node scripts/generate-telegram-schema-payloads.mjs",
    "telegram:schema:payloads:check": "node scripts/check-telegram-schema-payloads-generated.mjs",
    "telegram:schema:results:generate": "node scripts/generate-telegram-schema-results.mjs",
    "telegram:schema:results:check": "node scripts/check-telegram-schema-results-generated.mjs",
    "telegram:schema:release:gate": "node scripts/check-telegram-schema-release-gate.mjs",
    "docs": "typedoc src/index.ts --out docs/api",
    "api:snapshot:check": "node scripts/check-api-snapshot.mjs",
    "api:snapshot:update": "node scripts/update-api-snapshot.mjs",
    "prepublishOnly": "node scripts/enforce-ci-publish.mjs",
    "release:status": "changeset status",
    "changeset:lint": "node scripts/lint-changesets.mjs",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "test:published-smoke": "node scripts/published-smoke.mjs",
    "verify:release:ci": "pnpm changeset:lint && pnpm telegram:baseline:check && pnpm telegram:schema:types:check && pnpm telegram:schema:payloads:check && pnpm telegram:schema:results:check && pnpm test && pnpm typecheck:compat && pnpm -r typecheck && pnpm build && pnpm -r build && pnpm api:snapshot:check && pnpm pack:size && pnpm pack:starters",
    "verify:release": "node scripts/verify-release.mjs",
    "benchmark:trend:release": "BENCHMARK_MIN_RATIO=0.55 BENCHMARK_MIN_UPS=180000 node scripts/check-benchmark-trend.mjs",
    "telegram:schema:coverage:full:check": "node scripts/check-telegram-schema-full-coverage.mjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "verify:precommit": "node scripts/check-precommit-deps.mjs",
    "hooks:install": "git config core.hooksPath .githooks",
    "release:versions:check": "node scripts/check-release-versions-latest.mjs",
    "release:versions:sync": "node scripts/sync-release-versions.mjs",
    "sync:examples:published": "node scripts/sync-examples.mjs",
    "sync:examples:npm": "node scripts/sync-examples.mjs --from-npm"
  },
  "keywords": [
    "telegram",
    "bot",
    "framework",
    "fsm",
    "serverless"
  ],
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist-cjs/**/*.js",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
