{
  "name": "@tgwrapper/adapter-redis",
  "version": "0.8.1",
  "description": "Redis storage adapter for TGWrapper providing distributed sessions, caching namespaces, and rate limiters",
  "repository": {
    "type": "git",
    "url": "https://github.com/jilimb0/TGWrapper"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/jilimb0/TGWrapper/tree/main/packages/adapter-redis#readme",
  "bugs": {
    "url": "https://github.com/jilimb0/TGWrapper/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jilimb0"
  },
  "keywords": [
    "telegram",
    "bot",
    "redis",
    "ratelimit",
    "session",
    "fsm",
    "tgwrapper"
  ],
  "type": "module",
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm build:esm && pnpm build:cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:integration": "vitest run test/redis.integration.test.ts",
    "prepublishOnly": "node ../../scripts/enforce-ci-publish.mjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json"
  },
  "dependencies": {
    "ioredis": "^5.9.3"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist-cjs/**/*.js",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
