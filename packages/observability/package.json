{
  "name": "@tgwrapper/observability",
  "version": "0.9.2",
  "description": "First-party telemetry, logging, metrics, and trace correlation for TGWrapper",
  "repository": {
    "type": "git",
    "url": "https://github.com/jilimb0/TGWrapper"
  },
  "license": "Apache-2.0",
  "homepage": "https://github.com/jilimb0/TGWrapper/tree/main/packages/observability#readme",
  "bugs": {
    "url": "https://github.com/jilimb0/TGWrapper/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/jilimb0"
  },
  "keywords": [
    "telegram",
    "bot",
    "observability",
    "metrics",
    "tracing",
    "opentelemetry",
    "prometheus",
    "tgwrapper"
  ],
  "type": "module",
  "main": "./dist-cjs/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist-cjs/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "pnpm build:esm && pnpm build:cjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "node ../../scripts/enforce-ci-publish.mjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json"
  },
  "devDependencies": {
    "typescript": "6.0.3",
    "@types/node": "^25.6.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist-cjs/**/*.js",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
