    "telegram:baseline:followup:check": "node scripts/check-baseline-followup.mjs origin/main",
    "telegram:types:stub": "node scripts/generate-telegram-type-stubs.mjs",
    "telegram:schema:fetch": "node scripts/fetch-telegram-schema.mjs --out=docs/telegram-api-schema.latest.json",
    "telegram:schema:fetch:ci": "node scripts/fetch-telegram-schema.mjs --out=docs/telegram-api-schema.latest.json --allow-network-failure",
    "telegram:schema:fetch:local": "node scripts/fetch-telegram-schema.mjs --from-local --out=docs/telegram-api-schema.latest.json",
    "telegram:schema:completeness:check": "node scripts/check-telegram-schema-completeness.mjs",
    "telegram:schema:drift:report": "node scripts/diff-telegram-schema.mjs --latest=docs/telegram-api-schema.latest.json --snapshot=docs/telegram-api-schema.snapshot.json --report=docs/telegram-api-schema.drift-report.json",
    "telegram:schema:drift:check": "node scripts/diff-telegram-schema.mjs --latest=docs/telegram-api-schema.latest.json --snapshot=docs/telegram-api-schema.snapshot.json --report=docs/telegram-api-schema.drift-report.json --check",
    "telegram:schema:snapshot:update": "node scripts/promote-telegram-schema-snapshot.mjs",
    "telegram:schema:types:generate": "node scripts/generate-telegram-schema-types.mjs",
    "telegram:schema:types:check": "node scripts/check-telegram-schema-types-generated.mjs",
    "telegram:schema:payloads:generate": "node scripts/generate-telegram-schema-payloads.mjs",
    "telegram:schema:payloads:check": "node scripts/check-telegram-schema-payloads-generated.mjs",
    "telegram:schema:results:generate": "node scripts/generate-telegram-schema-results.mjs",
    "telegram:schema:results:check": "node scripts/check-telegram-schema-results-generated.mjs",
    "telegram:schema:release:gate": "node scripts/check-telegram-schema-release-gate.mjs",
    "docs": "typedoc src/index.ts --out docs/api",
    "api:snapshot:check": "node scripts/check-api-snapshot.mjs",
    "api:snapshot:update": "node scripts/update-api-snapshot.mjs",
    "release:status": "changeset status",
    "changeset:lint": "node scripts/lint-changesets.mjs",
    "release:version": "changeset version",
    "release:publish": "changeset publish",
    "test:published-smoke": "node scripts/published-smoke.mjs",
    "verify:release": "pnpm changeset:lint && pnpm telegram:baseline:check && pnpm telegram:schema:types:check && pnpm telegram:schema:payloads:check && pnpm telegram:schema:results:check && pnpm test && pnpm typecheck:compat && pnpm -r typecheck && pnpm build && pnpm -r build && pnpm api:snapshot:check && pnpm pack:size",
    "benchmark:trend:release": "BENCHMARK_MIN_RATIO=0.55 BENCHMARK_MIN_UPS=180000 node scripts/check-benchmark-trend.mjs",
    "check:1.0:readiness": "node scripts/check-1-0-readiness.mjs",
    "verify:1.0": "pnpm verify:release && pnpm telegram:schema:completeness:check && pnpm telegram:schema:coverage:full:check && pnpm benchmark && pnpm benchmark:trend:release && pnpm check:1.0:readiness",
    "telegram:schema:coverage:full:check": "node scripts/check-telegram-schema-full-coverage.mjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json"
